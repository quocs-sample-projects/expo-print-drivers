{
  "name": "expo-print-drivers",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "compile": "tsc",
    "start": "expo start",
    "android:debug": "expo run:android",
    "android:release": "expo run:android --variant release",
    "ios:debug": "expo run:ios",
    "ios:release": "expo run:ios --configuration Release",
    "prebuild": "expo prebuild --clean",
    "build:apk": "cd android && ./gradlew assembleRelease && cd ..",
    "doctor": "npx expo-doctor",
    "add:install": "npx expo install",
    "add:check": "npx expo install --check",
    "add:fix": "npx expo install --fix",
    "project:clear": "rm -rf node_modules android ios && bun pm cache rm",
    "project:bootstrap": "bun install && bun prebuild"
  },
  "dependencies": {
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "@types/lodash": "^4.17.24",
    "expo": "^55.0.17",
    "expo-application": "~55.0.14",
    "expo-dev-client": "~55.0.28",
    "expo-file-system": "~55.0.17",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.16",
    "lodash": "^4.18.1",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "sharp-cli": "^5.2.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "typescript": "~5.9.3"
  },
  "private": true
}
